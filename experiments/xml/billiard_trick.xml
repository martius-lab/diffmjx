<mujoco model="billiard">
    <visual>
        <quality shadowsize="4096" />
        <global offwidth="800" offheight="800" />
        <rgba haze="1 1 1 1" />
        <headlight ambient="0.5 0.5 0.5" diffuse="0.6 0.6 0.6" specular="0.5 0.5 0.5" />
    </visual>

    <default>
        <geom solimp="0.9 0.95 0.01 0.5 2" solref="0.01 0.2" condim="3"/>
    </default> 

    <option impratio="10" iterations="1" ls_iterations="4" timestep="0.001">
        <flag warmstart="enable" refsafe="disable"/>
    </option>

    <custom>
        <numeric data="15" name="max_contact_points"/>
        <numeric data="15" name="max_geom_pairs"/>
    </custom>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="1. 1. 1." rgb2="1. 1. 1." width="32" height="512"/>

        <!-- Green Felt Table Texture -->
        <texture name="felt" type="2d" builtin="flat" rgb1="0.05 0.4 0.05" rgb2="0.05 0.4 0.05" width="512" height="512"/>
        <material name="felt" texture="felt" texuniform="true" reflectance="0.1" rgba="0.1 0.5 0.1 1"/>

        <!-- Wooden Cushion Texture -->
        <texture name="wood" type="2d" builtin="checker" rgb1="0.4 0.2 0.1" rgb2="0.3 0.15 0.07" width="128" height="128"/>
        <material name="wood" texture="wood" texrepeat="3 3" texuniform="true" reflectance="0.2" rgba="0.4 0.2 0.1 1"/>

        <!-- Cue Ball with Rolling Marker (Red & White Checker) -->
        <texture name="cue_ball" type="cube" builtin="flat" mark="cross" width="64" height="64" rgb1="0.9 0.9 0.9" rgb2="0.9 0.9 0.9" markrgb="0 0 0"/>
        <material name="cue_ball" texture="cue_ball" texuniform="true" rgba="1 1 1 1." reflectance="0.7"/>
        
        <!-- Ball Material (reuse eight_ball texture for the rack balls) -->
        <texture name="eight_ball" type="cube" builtin="flat" mark="cross" width="64" height="64" rgb1="0.1 0.1 0.1" rgb2="0.1 0.1 0.1" markrgb="1 1 1"/>
        <material name="eight_ball" texture="eight_ball" texuniform="true" rgba="1 1 1 1."/>
        
        <texture name="red_ball" type="cube" builtin="flat" mark="cross" width="64" height="64" rgb1="0.5 0.1 0.1" rgb2="0.5 0.1 0.1" markrgb="1 1 1"/>
        <material name="red_ball" texture="red_ball" texuniform="true" rgba="1 1 1 1."/>
    </asset>

    <worldbody>
        <!-- Billiard Table Surface -->
        <geom name="table" type="plane" material="felt" size="1.2 0.6 0.02" pos="0 0 -0.015" contype="1" conaffinity="2"/>

        <!-- Wooden Cushions -->
        <geom name="cushion1" type="box" material="wood" size="1.25 0.05 0.05" pos="0 0.65 0.025"/>
        <geom name="cushion2" type="box" material="wood" size="1.25 0.05 0.05" pos="0 -0.65 0.025"/>
        <geom name="cushion3" type="box" material="wood" size="0.05 0.6 0.05" pos="1.2 0 0.025"/>
        <geom name="cushion4" type="box" material="wood" size="0.05 0.6 0.05" pos="-1.2 0 0.025"/>

        <!-- Lighting -->
        <light directional="true" diffuse="0.5 0.5 0.5" specular="0.4 0.4 0.4" pos="0 0 3" dir="0 0 -1"/>
        <light directional="true" diffuse="0.4 0.4 0.4" specular="0.2 0.2 0.2" pos="0.2 0.2 3" dir="-1 -1 -1"/>

        <!-- Cameras -->
        <camera name="centric_angle" pos="-1.956 -0.019 1.330" xyaxes="-0.001 -1.000 -0.000 0.665 -0.000 0.747"/>
        <camera name="side_angle" pos="0.012 -2.497 1.323" xyaxes="1.000 -0.000 -0.000 0.000 0.449 0.894"/>
        <camera name="birdseye_close" pos="0 0 1.2" xyaxes="1 0 0 0 1 0"/>
        <camera name="birdseye" pos="0.000 -0.040 2.295" xyaxes="1.000 0.003 0.000 -0.003 1.000 0.017"/>

        <!-- Cue Ball at Typical Start Position (remains on the left side) -->
        <body name="cue_ball" pos="-0.8 0 0.035">
            <joint type="free" damping="0.0001"/>
            <geom name="cue_geom" type="sphere" size="0.042" material="cue_ball" mass="0.17" contype="7" friction="0.2 0.01 0.01"/>
        </body>

        <!-- 6-Ball Rack (rotated by 180° relative to its center) -->
        <!-- Row 1 (Apex, now closest to the cue ball) -->
        <body name="ball1" pos="0.705 0 0.035">
            <joint type="free" damping="0.0001"/>
            <geom name="ball1_geom" type="sphere" size="0.042" material="eight_ball" mass="0.17" contype="7" friction="0.2 0.01 0.01"/>
        </body>
        <!-- Row 2 -->
        <body name="ball2" pos="0.779 -0.042 0.035">
            <joint type="free" damping="0.0001"/>
            <geom name="ball2_geom" type="sphere" size="0.042" material="eight_ball" mass="0.17" contype="7" friction="0.2 0.01 0.01"/>
        </body>
        <body name="ball3" pos="0.779 0.042 0.035">
            <joint type="free" damping="0.0001"/>
            <geom name="ball3_geom" type="sphere" size="0.042" material="eight_ball" mass="0.17" contype="7" friction="0.2 0.01 0.01"/>
        </body>
        <!-- Row 3 -->
        <body name="eight_ball" pos="0.852 -0.084 0.035">
            <joint type="free" damping="0.0001"/>
            <geom name="ball4_geom" type="sphere" size="0.042" material="red_ball" mass="0.17" contype="7" friction="0.2 0.01 0.01"/>
        </body>
        <body name="ball5" pos="0.852 0.000 0.035">
            <joint type="free" damping="0.0001"/>
            <geom name="ball5_geom" type="sphere" size="0.042" material="eight_ball" mass="0.17" contype="7" friction="0.2 0.01 0.01"/>
        </body>
        <body name="ball6" pos="0.852 0.084 0.035">
            <joint type="free" damping="0.0001"/>
            <geom name="ball6_geom" type="sphere" size="0.042" material="eight_ball" mass="0.17" contype="7" friction="0.2 0.01 0.01"/>
        </body>

        <!-- Mocap Target in the Right Corner (unchanged) -->
        <body mocap="true" name="mocap_target" pos="1. -0.5 0.02">
            <geom type="sphere" size="0.025" rgba="1 0 0 1" contype="0" conaffinity="0"/>
        </body>
    </worldbody>
</mujoco>
